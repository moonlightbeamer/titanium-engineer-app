# ── GitHub App ────────────────────────────────────────────────────────────────
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ── Azure OpenAI (primary LLM — ReviewAgent) ──────────────────────────────────
# Find these in Azure Portal → your OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o            # name of your GPT-4o deployment
AZURE_OPENAI_API_VERSION=2024-08-01-preview    # update to latest stable as needed

# ── Azure AI Foundry — Claude (primary LLM when set; fallback to Azure OpenAI) ──
# Find these in Azure AI Foundry → your project → Overview → API keys
AZURE_ANTHROPIC_API_KEY=your_azure_anthropic_key
AZURE_ANTHROPIC_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022  # deployment/model name in your AI Foundry project

# ── Backing services ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pr_reviewer
REDIS_URL=redis://localhost:6379/0
CHROMADB_URL=http://localhost:8001

# ── App behaviour ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARN
